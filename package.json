{
  "publisher": "will670",
  "repository": {
    "type": "git",
    "url": "https://github.com/sywc670/mlink"
  },
  "license": "MIT",
  "name": "mlink",
  "displayName": "MLink",
  "description": "Markdown links and backlinks",
  "version": "0.3.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mlink.refreshIndex",
        "title": "MLink: Refresh Workspace Index",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mlink.refreshIndex",
          "when": "view == mlink-links && mlink.isMarkdownEditor",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mlink-explorer",
          "title": "MLink",
          "icon": "$(link)",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "views": {
      "mlink-explorer": [
        {
          "icon": "$(link)",
          "id": "mlink-links",
          "name": "Links",
          "when": "mlink.isMarkdownEditor"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "unit-test": "npm run compile-tests && node --test out/test/*.test.js",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
